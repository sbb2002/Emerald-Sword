# 환경변수 템플릿 — 실제 값은 Render 대시보드(Environment)에만 입력한다.
# 이 파일을 복사해 .env 로 만들어 로컬 개발에 쓴다(.env 는 .gitignore 대상).
# 실제 비밀값을 이 파일이나 .env 에 채운 채 커밋하지 말 것.

# ===== 필수 (Phase A) =====
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
TELEGRAM_BOT_TOKEN=123456789:ABCdef-your-bot-token
TELEGRAM_CHAT_ID=123456789

# ===== KIS Open API (Phase B 에서 사용) =====
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_CANO_REAL=
KIS_CANO_PAPER=
KIS_ACNT_PRDT_CD=01
KIS_BASE_URL_REAL=
KIS_BASE_URL_PAPER=
